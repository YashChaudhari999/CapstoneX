<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.Capstone.CardView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_with_border"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTimelineTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Topic Approval"
            style="@style/Capstone.Text.SectionHeader"
            app:layout_constraintEnd_toStartOf="@+id/tvTimelineStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTimelineStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorMainBg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="PENDING"
            android:textColor="@color/colorAccentOrange"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTimelineDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Due: 15 Aug 2024"
            style="@style/Capstone.Text.Muted"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTimelineTitle" />

        <ProgressBar
            android:id="@+id/pbTimeline"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:progress="0"
            android:progressTint="@color/colorAccentTeal"
            app:layout_constraintTop_toBottomOf="@id/tvTimelineDate" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>