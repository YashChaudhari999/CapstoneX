<?xml version="1.0" encoding="utf-8"?><!-- ═══ res/layout/dialog_add_log_entry.xml (Fixed Overlap) ═══ -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorCardBg"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Log Entry"
            android:textColor="@color/colorLearningNavy"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            style="@style/Capstone.Text.Muted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Weekly activity report" />

        <View
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="16dp"
            android:background="@color/colorOuterBg" />

        <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            xmlns:tools="http://schemas.android.com/tools"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorCardBg"
                android:orientation="vertical"
                android:padding="24dp">
                <!-- From Date Input -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="From Date" />

                <CalendarView
                    android:id="@+id/etFromDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="From Date"
                    android:textColor="@color/colorBodyText"
                    tools:ignore="RtlSymmetry" />

                <!-- To Date Input -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="To Date" />

                <CalendarView
                    android:id="@+id/etToDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="To Date"
                    android:textColor="@color/colorBodyText"
                    tools:ignore="RtlSymmetry" />

                <!-- Work Carried Out Input -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Capstone.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:counterEnabled="true"
                    app:counterMaxLength="500">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWorkDone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:hint="@string/hint_work_carried_out"
                        android:inputType="textMultiLine"
                        android:minLines="4"
                        android:textColor="@color/colorBodyText" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCancel"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_cancel"
                        android:textColor="@color/colorMutedText" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddEntry"
                        style="@style/Widget.Capstone.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:paddingHorizontal="24dp"
                        android:text="@string/btn_add_entry" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
