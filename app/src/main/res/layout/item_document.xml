<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.Capstone.CardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_with_border"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivDocIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_book"
            app:tint="@color/colorTopBar" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDocTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proposal_v1.pdf"
                style="@style/Capstone.Text.SectionHeader"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvDocInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Uploaded: 12 Oct 2024"
                style="@style/Capstone.Text.Muted" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDownloadDoc"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIEW"
            android:textColor="@color/colorDashboardRed" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>