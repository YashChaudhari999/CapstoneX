<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.Capstone.CardView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_with_border"
        android:padding="16dp">

        <!-- Header Row: Week/Date and Status Badge -->
        <TextView
            android:id="@+id/tvWeekLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="WEEK 04 (01/03/24 - 07/03/24)"
            style="@style/Capstone.Text.CardLabel"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvStatusBadge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/colorMainBg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="SIGNED"
            android:textColor="@color/colorAccentGreen"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Body: Work Carried Out -->
        <TextView
            android:id="@+id/tvWorkTextLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="WORK CARRIED OUT"
            style="@style/Capstone.Text.CardLabel"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWeekLabel" />

        <TextView
            android:id="@+id/tvWorkText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Implemented the initial CNN architecture for image classification. Processed dataset for training and validation."
            style="@style/Capstone.Text.Body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvWorkTextLabel" />

        <!-- Mentor Remark Section -->
        <View
            android:id="@+id/dividerRemark"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/colorOuterBg"
            app:layout_constraintTop_toBottomOf="@id/tvWorkText" />

        <TextView
            android:id="@+id/tvMentorRemarkLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="MENTOR REMARK"
            style="@style/Capstone.Text.CardLabel"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerRemark" />

        <TextView
            android:id="@+id/tvMentorRemark"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Good progress. Focus on improving accuracy in the next iteration."
            style="@style/Capstone.Text.Muted"
            android:textStyle="italic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMentorRemarkLabel" />

        <!-- Footer: Grade and Action Button -->
        <TextView
            android:id="@+id/tvGrade"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Grade: 9/10"
            style="@style/Capstone.Text.Body"
            android:textColor="@color/colorLearningNavy"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvMentorRemark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignLog"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIEW DETAILS"
            android:textColor="@color/colorDashboardRed"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvGrade" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>