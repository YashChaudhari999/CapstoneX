<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.Capstone.CardView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_with_border"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStudentAvatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivStudentAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_person" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvStudentName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Student Name"
            style="@style/Capstone.Text.SectionHeader"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardStudentAvatar"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvStudentSap"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="SAP ID: 70012345678"
            style="@style/Capstone.Text.Body"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvStudentName"
            app:layout_constraintTop_toBottomOf="@id/tvStudentName" />

        <TextView
            android:id="@+id/tvStudentRoll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Roll No: A265"
            style="@style/Capstone.Text.Muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvStudentSap"
            app:layout_constraintTop_toBottomOf="@id/tvStudentSap" />

        <TextView
            android:id="@+id/tvStudentBranch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Branch: Information Technology"
            style="@style/Capstone.Text.Muted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvStudentRoll"
            app:layout_constraintTop_toBottomOf="@id/tvStudentRoll" />

        <TextView
            android:id="@+id/tvStudentGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Group: IT2026_1"
            style="@style/Capstone.Text.Body"
            android:textColor="@color/colorAccentTeal"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvStudentBranch"
            app:layout_constraintTop_toBottomOf="@id/tvStudentBranch" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewStudentLogs"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="VIEW LOGS"
            android:textColor="@color/colorLearningNavy"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStudentGroup" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteStudent"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REMOVE"
            android:textColor="@color/colorDashboardRed"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnViewStudentLogs" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>