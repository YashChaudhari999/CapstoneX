<!-- ═══ res/layout/item_review_param.xml (FIXED — Guaranteed No Overlap) ═══ -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <!-- Use a horizontal LinearLayout as root to separate the accent bar from content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 1. Left Accent Bar -->
        <View
            android:id="@+id/vAccentBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/colorNavy" />

        <!-- 2. Main Content Container (Vertical flow ensures no vertical overlap) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Row: [Letter] [Title] [Badge] -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvParamLetter"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_badge_grey"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="@color/colorNavy"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvParamTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Technical Implementation"
                    android:textColor="@color/colorNavy"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvScoreBadge"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/colorNavyLight"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tvCurrentScore"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/colorNavy"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Description (Indented to match title) -->
            <TextView
                android:id="@+id/tvParamDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="36dp"
                android:layout_marginTop="4dp"
                android:text="Depth of technical complexity and implementation quality."
                android:textColor="@color/colorTextMuted"
                android:textSize="11sp" />

            <!-- SeekBar Container -->
            <SeekBar
                android:id="@+id/sbScore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:max="3"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:progress="1"
                android:progressTint="@color/colorNavy"
                android:thumbTint="@color/colorGold" />

            <!-- Scale Labels -->
            <LinearLayout
                android:id="@+id/llScaleLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Poor"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Fair"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Good"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Excellent"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="9sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
