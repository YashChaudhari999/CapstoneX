<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/logbook_details_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorMainBg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorTopBar"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="95dp"
            android:layout_marginBottom="1dp"
            android:paddingTop="35dp"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="#FFFFFF">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CapstoneX Log Details"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Header Section -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_with_border"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvDetailWeek"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Week 04 Progress Report"
                            style="@style/Capstone.Text.SectionHeader" />

                        <TextView
                            android:id="@+id/tvDetailStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@color/colorMainBg"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:text="COMPLETED"
                            android:textColor="@color/colorAccentGreen"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDetailDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="01 Mar 2024 – 07 Mar 2024"
                        style="@style/Capstone.Text.Muted" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/colorOuterBg" />

                    <TextView
                        android:id="@+id/tvDetailScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade: 9.5 / 10"
                        android:textColor="@color/colorLearningNavy"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Detailed Work Breakdown -->
            <TextView
                style="@style/Capstone.Text.CardLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="DETAILED WORK BREAKDOWN"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDetailWorkDesc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Expanded description of work done..."
                        style="@style/Capstone.Text.Body" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Technologies Used:"
                        style="@style/Capstone.Text.CardLabel"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailTech"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="TensorFlow, OpenCV, Python"
                        style="@style/Capstone.Text.Body" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3 & 4. Metrics & Learning -->
            <TextView
                style="@style/Capstone.Text.CardLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="OUTCOMES &amp; LEARNING"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDetailMetrics"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Accuracy achieved: 92%"
                        style="@style/Capstone.Text.Body" />

                    <TextView
                        android:id="@+id/tvDetailLearning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Concepts learned: Convolutional layers tuning..."
                        style="@style/Capstone.Text.Body" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5 & 6. Challenges & Feedback -->
            <TextView
                style="@style/Capstone.Text.CardLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="CHALLENGES &amp; FEEDBACK"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Issues Encountered:"
                        style="@style/Capstone.Text.CardLabel"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailIssues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Overfitting observed on smaller dataset."
                        style="@style/Capstone.Text.Body" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/colorOuterBg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mentor Feedback:"
                        style="@style/Capstone.Text.CardLabel"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailFeedback"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Detailed remarks from mentor will appear here."
                        style="@style/Capstone.Text.Muted"
                        android:textStyle="italic" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 7. Next Steps -->
            <TextView
                style="@style/Capstone.Text.CardLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="ACTION PLAN"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvDetailNextSteps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Augment dataset\n2. Re-train with dropout"
                        style="@style/Capstone.Text.Body" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 9. Navigation / Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownloadReport"
                    style="@style/Widget.Capstone.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DOWNLOAD REPORT (PDF)"
                    app:icon="@drawable/ic_book" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditLog"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="EDIT LOG ENTRY"
                    app:strokeColor="@color/colorDashboardRed"
                    android:textColor="@color/colorDashboardRed" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>