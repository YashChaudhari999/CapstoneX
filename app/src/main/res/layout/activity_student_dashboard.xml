<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/student_dashboard_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorOuterBg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorTopBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:minHeight="?attr/actionBarSize"
            android:paddingTop="35dp"
            app:contentInsetStart="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvToolbarProfile"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerVertical="true"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp">
                    <ImageView
                        android:id="@+id/ivToolbarAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/cvToolbarProfile"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:text="Hi, Student! 👋"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivNotifications"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/ic_launcher_background"
                    android:padding="6dp"
                    android:src="@drawable/ic_bell"
                    app:tint="@color/colorAccentYellow" />
            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/colorMainBg"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                style="@style/Capstone.Text.SectionHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="DASHBOARD OVERVIEW" />

            <!-- Project Details (Visible only when in group) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGroupInfo"
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_with_border"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvDisplayGroupName"
                        style="@style/Capstone.Text.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Project Group Active" />
                    <TextView
                        android:id="@+id/tvDisplayMembers"
                        style="@style/Capstone.Text.Muted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Members assigned" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TILE GRID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Row 1: Timeline | Documents -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileTimeline"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp" android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentBlue" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_calendar" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView style="@style/Capstone.Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Timeline" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileDocuments"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp" android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentTeal" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_book" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView style="@style/Capstone.Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Documents" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2: Register Group | Spacer -->
                <LinearLayout
                    android:id="@+id/rowRegisterGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileCreateGroup"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp" android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentYellow" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_plus" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView style="@style/Capstone.Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Register Group" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Spacer to keep size consistent -->
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                </LinearLayout>

                <!-- Row 3: View Group | Topic Approval -->
                <LinearLayout
                    android:id="@+id/rowGroupActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileViewGroup"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:visibility="gone"
                        tools:visibility="visible">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp" android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentGreen" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_person" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView style="@style/Capstone.Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="View Group" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tileTitleApproval"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:visibility="gone"
                        tools:visibility="visible">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp" android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorDashboardRed" app:cardCornerRadius="24dp" app:cardElevation="0dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_checklist" app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView style="@style/Capstone.Text.Body" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Topic Approval" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <!-- Project Progress -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Capstone.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_with_border"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        style="@style/Capstone.Text.SectionHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROJECT PROGRESS" />
                    <ProgressBar
                        android:id="@+id/pbOverall"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:progress="65"
                        android:progressTint="@color/colorAccentGreen" />
                    <TextView
                        android:id="@+id/tvProgressPercent"
                        style="@style/Capstone.Text.CardLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"
                        android:text="65% Completed" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View android:layout_width="match_parent" android:layout_height="100dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/colorSidebarBg"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_student" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
