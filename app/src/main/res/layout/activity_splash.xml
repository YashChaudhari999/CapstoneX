<!-- ═══ res/layout/activity_splash.xml (FIXED — No Overlap) ═══ -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorNavyDark">

    <!-- Main Branding Container (Logo + Texts)
         Using a LinearLayout ensures elements follow a strict vertical order
         and will never overlap each other. -->

    <LinearLayout
        android:id="@+id/llBranding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/tvAddress"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <!-- Logo Section with Decorative Ring -->
        <FrameLayout
            android:layout_width="180dp"
            android:layout_height="180dp">

            <!-- Decorative Ring -->
            <View
                android:id="@+id/viewRing"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.3"
                android:background="@drawable/bg_badge_gold" />

            <!-- Logo Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvLogo"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/colorWhite"
                app:cardCornerRadius="42dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/colorGold"
                app:strokeWidth="2dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/bg_navy_button" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- App Identity Texts -->
        <TextView
            android:id="@+id/tvUniversityName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.3"
            android:text="@string/university_name"
            android:textColor="@color/colorWhite"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/tvDeptName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/dept_full_name"
            android:textColor="@color/colorTextMuted"
            android:textSize="12sp" />

        <!-- Gold Divider -->
        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/app_name"
            android:textColor="@color/colorWhite"
            android:textSize="24sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/viewDivider"
            android:layout_width="100dp"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/colorGold" />

        <!-- Loading Animation Placeholder -->
        <LinearLayout
            android:id="@+id/llLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_badge_gold" />

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_badge_gold" />

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_margin="4dp"
                android:background="@drawable/bg_badge_gold" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/location_address"
        android:textColor="@color/colorTextMuted"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
