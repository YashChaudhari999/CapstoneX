<!-- ═══ res/layout/item_project_group.xml (FIXED — Guaranteed No Overlap) ═══ -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <!-- Use a horizontal LinearLayout as root to separate the accent bar from content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 1. Left Accent Bar -->
        <View
            android:id="@+id/vGroupStatus"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/colorNavy" />

        <!-- 2. Main Content Container (Vertical flow ensures no vertical overlap) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Row: [Group Title] [Review Status Badge] -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvGroupTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AI Based Smart Surveillance System"
                    android:textColor="@color/colorNavy"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvReviewStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_badge_gold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="R2 DUE"
                    android:textColor="@color/colorGoldDark"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Team Names Row -->
            <TextView
                android:id="@+id/tvTeamNames"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Aaryan Shah, Rohan Verma, Sneha Gupta"
                android:textColor="@color/colorTextMuted"
                android:textSize="11sp" />

            <!-- Progress Row: [ProgressBar] [Percentage] -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ProgressBar
                    android:id="@+id/pbGroupProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:layout_weight="1"
                    android:progress="45"
                    android:progressTint="@color/colorNavy" />

                <TextView
                    android:id="@+id/tvGroupPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="45%"
                    android:textColor="@color/colorNavy"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Last Log Date -->
            <TextView
                android:id="@+id/tvLastLogDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Last Log: 07 Mar 2024"
                android:textColor="@color/colorTextMuted"
                android:textSize="10sp" />

            <!-- Overdue Warning (Visibility handled via Java) -->
            <LinearLayout
                android:id="@+id/llOverdue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@color/colorWarnBg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/bg_badge_gold"
                    app:tint="@color/colorWarn" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="3 LOGS PENDING SIGNATURE"
                    android:textColor="@color/colorWarn"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewLogs"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="16dp"
                    android:text="@string/btn_view_logs"
                    android:textColor="@color/colorNavy"
                    android:textSize="11sp"
                    app:strokeColor="@color/colorNavy" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEvaluate"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:paddingHorizontal="16dp"
                    android:text="@string/btn_evaluate"
                    android:textSize="11sp"
                    app:backgroundTint="@color/colorNavy" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
