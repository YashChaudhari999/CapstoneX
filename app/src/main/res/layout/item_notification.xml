<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Widget.Capstone.CardView">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_with_border"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/vReadIndicator"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@color/colorAccentYellow"
            android:backgroundTint="@color/colorAccentYellow"
            android:visibility="visible" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Update"
                style="@style/Capstone.Text.SectionHeader"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvNotifMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Your proposal has been approved by the mentor."
                style="@style/Capstone.Text.Body"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNotifTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2 hours ago"
                style="@style/Capstone.Text.Muted" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>