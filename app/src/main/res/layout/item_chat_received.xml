<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvMessageReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="260dp"
        android:background="@drawable/bg_chat_received"
        android:padding="12dp"
        android:text="Good. Please submit it in the portal."
        android:textColor="@color/colorBodyText"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvTimeReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="10:35 AM"
        style="@style/Capstone.Text.Muted"
        android:textSize="10sp" />

</LinearLayout>