<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/admin_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorOuterBg"
    tools:context=".AdminDashboardActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/admin_content_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorTopBar"
            app:elevation="4dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/admin_toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="1dp"
                android:minHeight="?attr/actionBarSize"
                android:paddingTop="35dp"
                app:navigationIcon="@drawable/ic_menu"
                app:navigationIconTint="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Overview"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/colorMainBg"
            android:fillViewport="true"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ── System Overview Cards ─────────────────────────── -->
                <TextView
                    style="@style/Capstone.Text.SectionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM OVERVIEW" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:useDefaultMargins="false"
                    android:alignmentMode="alignMargins">

                    <!-- Groups Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardGroups"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentBlue"
                                app:cardCornerRadius="24dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_checklist"
                                    app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tvGroupCount"
                                style="@style/Capstone.Text.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="— Groups" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Students Card (NEW) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardStudents"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentGreen"
                                app:cardCornerRadius="24dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tvStudentCount"
                                style="@style/Capstone.Text.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="— Students" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mentors Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMentors"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentTeal"
                                app:cardCornerRadius="24dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tvMentorCount"
                                style="@style/Capstone.Text.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="— Mentors" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Topic Approval Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardTopicApproval"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentOrange"
                                app:cardCornerRadius="24dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_checklist"
                                    app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                style="@style/Capstone.Text.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Topic Approval"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Add Domain Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAddDomain"
                        style="@style/Widget.Capstone.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardBackgroundColor="@color/colorAccentRed"
                                app:cardCornerRadius="24dp"
                                app:cardElevation="0dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_plus"
                                    app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                style="@style/Capstone.Text.Body"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Add Domain" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

                <!-- ── User Management Section ───────────────────────── -->
                <TextView
                    style="@style/Capstone.Text.SectionHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:text="USER MANAGEMENT" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.Capstone.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_with_border"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Info label -->
                        <TextView
                            style="@style/Capstone.Text.Muted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="Upload a CSV/Excel file with columns:\nemail, password, photoUrl"
                            android:textSize="12sp" />

                        <!-- Add Students Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddStudents"
                            style="@style/Widget.Capstone.Button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:drawableStart="@drawable/ic_person"
                            android:drawablePadding="8dp"
                            android:text="ADD STUDENTS  (Upload CSV/Excel)" />

                        <!-- Progress bar for student import -->
                        <ProgressBar
                            android:id="@+id/progressStudents"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:indeterminate="true"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvStudentImportStatus"
                            style="@style/Capstone.Text.Muted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textSize="12sp"
                            android:visibility="gone" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="16dp"
                            android:background="@color/colorOuterBg" />

                        <!-- Add Mentors Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddMentors"
                            style="@style/Widget.Capstone.Button"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:backgroundTint="@color/colorAccentTeal"
                            android:drawableStart="@drawable/ic_person"
                            android:drawablePadding="8dp"
                            android:text="ADD MENTORS  (Upload CSV/Excel)" />

                        <!-- Progress bar for mentor import -->
                        <ProgressBar
                            android:id="@+id/progressMentors"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:indeterminate="true"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvMentorImportStatus"
                            style="@style/Capstone.Text.Muted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textSize="12sp"
                            android:visibility="gone" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnExport"
                    style="@style/Widget.Capstone.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="80dp"
                    android:text="EXPORT ALL MARKS (CSV)" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/admin_nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/colorSidebarBg"
        app:itemIconTint="#FFFFFF"
        app:itemTextColor="#FFFFFF"
        app:menu="@menu/admin_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>